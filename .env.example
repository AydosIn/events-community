# Local development (SQLite — no setup required)
# DATABASE_URL is optional; defaults to ./data/events_community.db
# DATABASE_URL=sqlite:///./data/events_community.db

SECRET_KEY=change-me-for-non-local-use
ACCESS_TOKEN_EXPIRE_HOURS=720
CORS_ORIGINS=http://localhost:3000
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
ADMIN_EMAILS=aydosed@gmail.com

# Local development with PostgreSQL (optional)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/events_community

# Production (DigitalOcean App Platform + PostgreSQL)
# ENVIRONMENT=production
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
# SECRET_KEY=replace-with-a-long-random-secret
# CORS_ORIGINS=https://your-app.vercel.app
# GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
# ADMIN_EMAILS=aydosed@gmail.com
